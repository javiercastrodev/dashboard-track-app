---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LandingCard from '../../components/LandingCard.astro';
import { getLandingBySlug } from '../../lib/landings';

const { slug } = Astro.params;
const landing = slug ? await getLandingBySlug(slug) : null;

if (landing) {
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=30, stale-while-revalidate=60');
} else {
  Astro.response.status = 404;
}
---

<BaseLayout
  title={landing ? `${landing.title} — Tracking Dashboard` : 'Landing no encontrada — Tracking Dashboard'}
  description="Detalle de landing - Claro Tracking Dashboard"
  clientRouter={true}
>
  {landing ? (
    <div class="mb-4">
      <a
        href="/"
        class="inline-block text-sm text-blue-600 dark:text-blue-400 no-underline py-1.5 hover:underline transition-colors duration-200"
      >
        ← Volver al dashboard
      </a>
    </div>
    <LandingCard landing={landing} />
  ) : (
    <div class="flex flex-col items-center justify-center text-center py-16 px-6">
      <p class="text-5xl mb-4">🔍</p>
      <h1 class="text-2xl font-bold mb-3 text-gray-900 dark:text-gray-100 m-0">
        Landing no encontrada
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mb-6 text-base m-0">
        La landing <strong class="font-semibold">/{slug}</strong> no existe o no está registrada.
      </p>
      <a
        href="/"
        class="inline-block text-base px-4 py-2 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 no-underline rounded-lg mt-2 transition-all duration-200 hover:bg-blue-100 dark:hover:bg-blue-900/50"
      >
        ← Volver al dashboard
      </a>
    </div>
  )}
</BaseLayout>
