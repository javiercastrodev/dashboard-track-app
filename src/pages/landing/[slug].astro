---
/**
 * Página de detalle de una landing individual.
 *
 * SSR: busca la landing por slug en el archivo de datos.
 * - Slug conocido → renderiza LandingCard con toda la información.
 * - Slug desconocido → muestra 404 con mensaje y link de vuelta al dashboard.
 *
 * No usa getStaticPaths porque estamos en modo SSR (output: 'server') y
 * las landings cambian dinámicamente vía GitHub Action.
 *
 * @module pages/landing/[slug]
 */

import "../../styles/global.css";
import { ClientRouter } from 'astro:transitions';
import LandingCard from '../../components/LandingCard.astro';
import ThemeToggle from '../../components/ThemeToggle.astro';
import { getLandingBySlug } from '../../lib/landings';

const { slug } = Astro.params;

const landing = slug ? getLandingBySlug(slug) : null;
---

<!doctype html>
<html lang="es" class="motion-safe:scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      {landing ? `${landing.title} — Tracking Dashboard` : 'Landing no encontrada — Tracking Dashboard'}
    </title>
    <meta name="description" content="Detalle de landing - Claro Tracking Dashboard" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <ClientRouter />
  </head>
  <body
    class="m-0 font-sans bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col"
  >
    <!-- ============================================================
         Header
         ============================================================ -->
    <header
      class="sticky top-0 z-50 bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm border-b border-gray-200 dark:border-gray-700 transition-colors duration-300"
    >
      <div class="w-full max-w-5xl mx-auto px-5">
        <div class="flex items-center justify-between py-3">
          <a href="/" class="flex items-center gap-2 no-underline text-inherit">
            <span class="text-2xl leading-none">📡</span>
            <span class="text-lg font-bold text-gray-900 dark:text-white transition-colors duration-300">
              Tracking Dashboard
            </span>
          </a>

          <div class="flex items-center gap-1">
            <nav class="flex gap-0.5" aria-label="Navegación principal">
              <a
                href="/"
                class="px-3 py-2 text-sm font-medium text-gray-500 dark:text-gray-400 no-underline rounded-md transition-all duration-200 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400"
              >
                Dashboard
              </a>
              <a
                href="/subscribe"
                class="px-3 py-2 text-sm font-medium text-gray-500 dark:text-gray-400 no-underline rounded-md transition-all duration-200 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-gray-900 dark:hover:text-white"
              >
                Suscripción
              </a>
            </nav>
            <ThemeToggle />
          </div>
        </div>
      </div>
    </header>

    <!-- ============================================================
         Main
         ============================================================ -->
    <main class="w-full max-w-5xl mx-auto px-5 flex-1 pt-5 pb-8 animate-fade-in">
      {landing ? (
        <!-- Landing encontrada → renderiza detalle -->
        <div class="mb-4">
          <a
            href="/"
            class="inline-block text-sm text-blue-600 dark:text-blue-400 no-underline py-1.5 hover:underline transition-colors duration-200"
          >
            ← Volver al dashboard
          </a>
        </div>
        <LandingCard landing={landing} />
      ) : (
        <!-- Landing no encontrada → 404 -->
        {() => { Astro.response.status = 404; return null; }}
        <div class="flex flex-col items-center justify-center text-center py-16 px-6">
          <p class="text-5xl mb-4">🔍</p>
          <h1 class="text-2xl font-bold mb-3 text-gray-900 dark:text-gray-100 m-0">
            Landing no encontrada
          </h1>
          <p class="text-gray-500 dark:text-gray-400 mb-6 text-base m-0">
            La landing <strong class="font-semibold">/{slug}</strong> no existe o no está registrada.
          </p>
          <a
            href="/"
            class="inline-block text-base px-4 py-2 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 no-underline rounded-lg mt-2 transition-all duration-200 hover:bg-blue-100 dark:hover:bg-blue-900/50"
          >
            ← Volver al dashboard
          </a>
        </div>
      )}
    </main>

    <!-- ============================================================
         Footer
         ============================================================ -->
    <footer
      class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 py-3 transition-colors duration-300"
    >
      <div class="w-full max-w-5xl mx-auto px-5">
        <p class="m-0 text-xs text-gray-400 dark:text-gray-500">
          Tracking Dashboard — Claro
        </p>
      </div>
    </footer>
  </body>
</html>
