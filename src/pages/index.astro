---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingTable from '../components/LandingTable.astro';
import KpiCards from '../components/KpiCards.astro';
import { getAllLandings } from '../lib/landings';
import { formatTimestamp } from '../lib/dates';

const data = await getAllLandings();
const now = formatTimestamp(new Date());
Astro.response.headers.set('Cache-Control', 'public, s-maxage=30, stale-while-revalidate=60');
---

<BaseLayout
  title="Tracking Dashboard"
  description="Dashboard de seguimiento de landings - Claro"
  favicon="/icon-192.png"
>
  <KpiCards landings={data.landings} />
  <LandingTable
    landings={data.landings}
    lastUpdated={data.lastUpdated}
  />
  <Fragment slot="footer-content">Última actualización: {now}</Fragment>
</BaseLayout>
