---
const VAPID_PUBLIC_KEY = import.meta.env.PUBLIC_VAPID_KEY ?? '';
---

<div
  id="notif-modal-overlay"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/50 backdrop-blur-sm px-4"
>
  <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl w-full max-w-sm p-6 text-center border border-gray-200 dark:border-gray-700 transition-colors duration-300">
    <p class="text-4xl mb-3 m-0">🔔</p>
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 m-0 mb-2">
      ¿Activar notificaciones?
    </h2>
    <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed m-0 mb-6">
      Recibí una alerta cuando una landing haga un nuevo deploy o cambie de estado.
    </p>

    <p id="notif-modal-error" class="text-xs text-red-500 mb-3 hidden m-0"></p>

    <div class="flex flex-col gap-2">
      <button
        id="notif-modal-activate"
        class="w-full px-5 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 active:scale-[0.97] border-none bg-blue-600 text-white hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Activar
      </button>
      <button
        id="notif-modal-dismiss"
        class="w-full px-5 py-2 rounded-lg text-sm font-medium cursor-pointer transition-all duration-200 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 bg-transparent border-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Ahora no
      </button>
    </div>
  </div>
</div>

<div
  id="notif-toast"
  class="fixed bottom-5 left-1/2 -translate-x-1/2 z-[101] hidden bg-green-600 text-white text-sm font-semibold px-5 py-3 rounded-xl shadow-lg"
>
  ✅ Notificaciones activadas
</div>

<script define:vars={{ VAPID_PUBLIC_KEY }}>
  (function () {
    var VAPID_KEY = VAPID_PUBLIC_KEY;
    var DISMISS_KEY = 'push-modal-dismissed';
    var DISMISS_TTL_MS = 7 * 24 * 60 * 60 * 1000;

    var overlay = document.getElementById('notif-modal-overlay');
    var btnActivate = document.getElementById('notif-modal-activate');
    var btnDismiss = document.getElementById('notif-modal-dismiss');
    var errorEl = document.getElementById('notif-modal-error');
    var toast = document.getElementById('notif-toast');

    if (!overlay) return;

    function showModal() {
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
    }

    function hideModal() {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
    }

    function showToast() {
      if (!toast) return;
      toast.classList.remove('hidden');
      setTimeout(function () {
        toast.classList.add('hidden');
      }, 3500);
    }

    function setLoading(loading) {
      if (btnActivate) {
        btnActivate.disabled = loading;
        btnActivate.textContent = loading ? 'Activando...' : 'Activar';
      }
      if (btnDismiss) btnDismiss.disabled = loading;
    }

    function showError(msg) {
      if (!errorEl) return;
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }

    function clearError() {
      if (!errorEl) return;
      errorEl.classList.add('hidden');
      errorEl.textContent = '';
    }

    function urlBase64ToUint8Array(base64String) {
      var padding = '='.repeat((4 - (base64String.length % 4)) % 4);
      var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
      var rawData = atob(base64);
      var outputArray = new Uint8Array(rawData.length);
      for (var i = 0; i < rawData.length; ++i) {
        outputArray[i] = rawData.charCodeAt(i);
      }
      return outputArray;
    }

    async function shouldShow() {
      if (!('Notification' in window)) return false;
      if (!('serviceWorker' in navigator) || !('PushManager' in window)) return false;
      if (Notification.permission === 'denied') return false;
      var dismissed = localStorage.getItem(DISMISS_KEY);
      if (dismissed) {
        var ts = parseInt(dismissed, 10);
        if (!isNaN(ts) && Date.now() - ts < DISMISS_TTL_MS) return false;
      }
      if (Notification.permission === 'default') return true;
      // permission === 'granted': show only if there's no active subscription
      try {
        var reg = await navigator.serviceWorker.getRegistration('/sw.js');
        if (!reg) return true;
        var sub = await reg.pushManager.getSubscription();
        return !sub;
      } catch (e) {
        return false;
      }
    }

    async function handleActivate() {
      clearError();
      setLoading(true);

      try {
        await navigator.serviceWorker.register('/sw.js');
        var registration = await navigator.serviceWorker.ready;

        var permission = await Notification.requestPermission();
        if (permission !== 'granted') {
          // Browser dialog denied — close without setting dismiss flag
          // (permission is now 'denied', shouldShow() will return false on reload)
          hideModal();
          return;
        }

        var subscription = await registration.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: urlBase64ToUint8Array(VAPID_KEY),
        });

        var res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(subscription.toJSON()),
        });

        if (!res.ok) {
          await subscription.unsubscribe();
          showError('No se pudo guardar la suscripción. Intentalo de nuevo.');
          setLoading(false);
          return;
        }

        hideModal();
        showToast();
      } catch (err) {
        console.error('Error al activar notificaciones:', err);
        showError('Ocurrió un error. Intentalo de nuevo.');
        setLoading(false);
      }
    }

    function handleDismiss() {
      localStorage.setItem(DISMISS_KEY, String(Date.now()));
      hideModal();
    }

    if (btnActivate) btnActivate.addEventListener('click', handleActivate);
    if (btnDismiss) btnDismiss.addEventListener('click', handleDismiss);

    setTimeout(async function () {
      if (await shouldShow()) showModal();
    }, 1500);
  })();
</script>
